# Docker E2E only. These deterministic credentials are intentionally public and
# must never be used for development, staging, or production deployments.
POSTGRES_USER=eoffice_e2e
POSTGRES_PASSWORD=eoffice_e2e_postgres_password_not_for_production
POSTGRES_DB=eoffice_e2e
DATABASE_URL=postgresql://eoffice_e2e:eoffice_e2e_postgres_password_not_for_production@db:5432/eoffice_e2e

JWT_SECRET=e2e-only-jwt-secret-with-at-least-thirty-two-characters
REFRESH_TOKEN_SECRET=e2e-only-refresh-secret-with-at-least-thirty-two-chars
DEMO_ADMIN_PASSWORD=e2e-only-demo-password-not-for-production
E2E_ADMIN_PASSWORD=e2e-only-demo-password-not-for-production
E2E_ADMIN_EMAIL=admin@acme.local
E2E_INTERNAL_SIGNER_EMAIL=admin@acme.local

NODE_ENV=test
BACKEND_PORT=4010
FRONTEND_PORT=3010
CORS_ORIGIN=http://127.0.0.1:3010
APP_BASE_URL=http://127.0.0.1:3010
NEXT_PUBLIC_API_URL=http://127.0.0.1:4010/api/v1
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4010/api/v1
REDIS_URL=redis://redis:6379
FILE_STORAGE_DRIVER=local
STORAGE_BASE_PATH=./storage
SMTP_ENABLED=true
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=noreply@acme.local
AUTO_INIT_DB=true
DISABLE_LICENSE_CHECK=true
OUTBOX_POLL_INTERVAL_MS=250
RATE_LIMIT_BYPASS_EMAILS=admin@acme.local,manager@acme.local,staff.it@acme.local,legal@acme.local,finance@acme.local
