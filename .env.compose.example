# Copy to .env before running docker compose

POSTGRES_USER=eoffice
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=eoffice_db
POSTGRES_PORT=5432

REDIS_PORT=6379

LICENSE_SERVER_PORT=5000
LICENSE_SIGNING_SECRET=replace-me-license-secret
LICENSE_SERVER_URL=http://license-server:5000/api/v1

BACKEND_PORT=4000
DATABASE_URL=postgresql://eoffice:change-me-db-password@db:5432/eoffice_db
JWT_SECRET=replace-me-jwt-secret-with-32-chars-minimum
REFRESH_TOKEN_SECRET=replace-me-refresh-secret-with-32-chars-minimum
CORS_ORIGIN=http://localhost:3000
STORAGE_BUCKET=local
STORAGE_BASE_PATH=./storage
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.local
EMAIL_FROM_NAME=E-Office

FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
