# Copy to .env before running docker compose

POSTGRES_USER=eoffice
POSTGRES_PASSWORD=GENERATE_A_LONG_RANDOM_DATABASE_PASSWORD
POSTGRES_DB=eoffice_db
# Development-only port exposure lives in docker-compose.dev.yml.
POSTGRES_PORT=5432
REDIS_PORT=6379

# Optional: required only with `--profile license`.
LICENSE_SIGNING_SECRET=GENERATE_A_LONG_RANDOM_LICENSE_SECRET
LICENSE_SERVER_URL=

BACKEND_PORT=4000
DATABASE_URL=postgresql://eoffice:GENERATE_A_LONG_RANDOM_DATABASE_PASSWORD@db:5432/eoffice_db
JWT_SECRET=GENERATE_A_LONG_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
REFRESH_TOKEN_SECRET=GENERATE_A_LONG_RANDOM_REFRESH_SECRET_AT_LEAST_32_CHARS
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000
FILE_STORAGE_DRIVER=local
# S3-compatible storage (MinIO/R2/Ceph) is optional; local storage is default.
# S3_ENDPOINT=http://minio:9000
# S3_REGION=us-east-1
# S3_BUCKET=eoffice
# S3_ACCESS_KEY_ID=example-access-key
# S3_SECRET_ACCESS_KEY=example-secret-key
# S3_FORCE_PATH_STYLE=true
STORAGE_BASE_PATH=./storage
# Defaults match the backend Docker image. Override only for a custom font mount.
PDF_UNICODE_FONT_PATH=/usr/share/fonts/truetype/noto/NotoSans-Regular.ttf
PDF_UNICODE_BOLD_FONT_PATH=/usr/share/fonts/truetype/noto/NotoSans-Bold.ttf
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@example.local
EMAIL_FROM_NAME=E-Office
SMTP_ENABLED=false
# Keep production-safe defaults. Set AUTO_INIT_DB=true only for an isolated
# disposable demo database; it runs db push with accept-data-loss and seeds users.
AUTO_INIT_DB=false
# Required only when AUTO_INIT_DB=true. Never use a shared demo password.
DEMO_ADMIN_PASSWORD=
# Open-source Compose stack does not require the optional license service.
DISABLE_LICENSE_CHECK=true
RATE_LIMIT_BYPASS_EMAILS=

FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
