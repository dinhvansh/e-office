{
  "name": "wp-sign",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ../license-server && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
