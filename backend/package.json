{
  "name": "e-sign-backend",
  "version": "1.0.0",
  "main": "dist/server.js",
  "scripts": {
    "prebuild": "prisma generate",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "build:skip-check": "tsc --noEmit false --skipLibCheck",
    "start": "node dist/server.js",
    "start:dev": "ts-node-dev --transpile-only src/server.ts",
    "prisma": "prisma",
    "lint": "eslint --ext .ts src",
    "test": "tsc -p tsconfig.tests.json && node --env-file=tests/.env.test.example --test .test-dist/tests/*.test.js",
    "worker:outbox": "node dist/workers/outbox.worker.js",
    "test:e2e:workflow": "node scripts/e2e-workflow-refactor.js",
    "test:auth-matrix": "node scripts/test-authorization-matrix.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@prisma/client": "^5.22.0",
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^7.0.4",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dompurify": "^3.3.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.2.1",
    "fontkit": "^2.0.4",
    "form-data": "^4.0.5",
    "helmet": "^7.2.0",
    "ioredis": "^5.4.1",
    "isomorphic-dompurify": "^2.32.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-fetch": "^2.7.0",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.11.0",
    "undici": "^6.19.8",
    "uuid": "^11.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.6",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.2.5",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  }
}
