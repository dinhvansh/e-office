# Application
# Copy to .env and replace every REQUIRED placeholder with a unique secret.
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://YOUR_DATABASE_USER:GENERATE_A_LONG_RANDOM_DATABASE_PASSWORD@localhost:5432/esign_db

# JWT (minimum 32 characters; generate with crypto.randomBytes(32))
JWT_SECRET=GENERATE_A_LONG_RANDOM_JWT_SECRET_AT_LEAST_32_CHARS
REFRESH_TOKEN_SECRET=GENERATE_A_LONG_RANDOM_REFRESH_SECRET_AT_LEAST_32_CHARS
TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d

# Local development services
REDIS_URL=redis://localhost:6379
LICENSE_SERVER_URL=http://license-server:5000
CORS_ORIGIN=http://localhost:3000
APP_BASE_URL=http://localhost:3000

# Storage: local is the default. Configure S3 values only when selecting s3.
FILE_STORAGE_DRIVER=local
STORAGE_BASE_PATH=./storage
# S3_ENDPOINT=https://object.example.invalid
# S3_REGION=us-east-1
# S3_BUCKET=eoffice
# S3_ACCESS_KEY_ID=example-access-key
# S3_SECRET_ACCESS_KEY=example-secret-key
# S3_FORCE_PATH_STYLE=true

# Email is disabled by default. Never commit SMTP credentials.
SMTP_ENABLED=false
SMTP_HOST=smtp.example.invalid
SMTP_PORT=587
SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
EMAIL_FROM=noreply@example.invalid
EMAIL_FROM_NAME=E-Office

# Cookies and optional license service
AUTH_COOKIE_NAME=esign_rt
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
DISABLE_LICENSE_CHECK=true
