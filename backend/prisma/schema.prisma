generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model tenants {
  id         Int         @id @default(autoincrement())
  name       String?
  domain     String?
  logo_url   String?
  plan       String?
  status     String?
  created_at DateTime    @default(now())
  users      users[]
  documents  documents[]
  sign_requests sign_requests[]
  departments departments[]
  positions  positions[]
  roles      roles[]
  document_types document_types[]
  numbering_rules numbering_rules[]
  external_organizations external_organizations[]
  workflows  workflows[]
}

model users {
  id            Int        @id @default(autoincrement())
  tenant_id     Int
  email         String     @unique
  password_hash String
  full_name     String?
  phone         String?
  avatar_url    String?
  department_id Int?
  manager_id    Int?       // Quản lý trực tiếp
  position_id   Int?       // Chức danh
  role          String?    @default("user")
  status        String?    @default("active")
  created_at    DateTime   @default(now())
  tenant        tenants    @relation(fields: [tenant_id], references: [id])
  department    departments? @relation("user_department", fields: [department_id], references: [id])
  manager       users?     @relation("user_manager", fields: [manager_id], references: [id], onDelete: SetNull)
  subordinates  users[]    @relation("user_manager")
  position      positions? @relation("user_position", fields: [position_id], references: [id])
  documents     documents[] @relation("documents_owner")
  audit_logs    audit_logs[]
  user_roles    user_roles[]
  managed_departments departments[] @relation("department_manager")
  approvals     document_approvals[]
}

model documents {
  id                 Int           @id @default(autoincrement())
  tenant_id          Int
  owner_id           Int?
  document_type_id   Int?
  department_id      Int?
  file_path          String
  original_file_name String?
  hash               String?
  status             String?
  version            Int           @default(1)
  document_number    String?
  numbering_rule_id  Int?
  title              String?
  summary            String?
  priority_level     String?       @default("normal")
  confidential_level String?       @default("normal")
  visibility_scope   String?       @default("public")
  effective_date     DateTime?
  expiration_date    DateTime?
  issued_date        DateTime?
  sign_request_id    Int?          @unique
  created_at         DateTime      @default(now())
  tenant             tenants       @relation(fields: [tenant_id], references: [id])
  owner              users?        @relation("documents_owner", fields: [owner_id], references: [id])
  document_type      document_types? @relation(fields: [document_type_id], references: [id])
  department         departments?  @relation(fields: [department_id], references: [id])
  sign_request       sign_requests? @relation("document_sign_request", fields: [sign_request_id], references: [id])
  sign_requests      sign_requests[] @relation("document_all_sign_requests")
  audit_logs         audit_logs[]
  tags               document_tags[]
  permissions        document_permissions[]
  versions           document_versions[]
  workflow_instance  workflow_instances?
  approvals          document_approvals[]
  sign_fields        sign_request_fields[]
  cc_emails          document_cc_emails[]
  attachments        document_attachments[]

  @@index([department_id])
  @@index([sign_request_id])
}

model sign_requests {
  id            Int        @id @default(autoincrement())
  tenant_id     Int
  document_id   Int
  title         String?
  message       String?
  workflow_type String?
  status        String?
  deadline      DateTime?
  auto_created  Boolean    @default(false)
  created_at    DateTime   @default(now())
  tenant        tenants    @relation(fields: [tenant_id], references: [id])
  document      documents  @relation("document_all_sign_requests", fields: [document_id], references: [id])
  linked_document documents? @relation("document_sign_request")
  signers       signers[]
  fields        sign_request_fields[]
}

model signers {
  id             Int           @id @default(autoincrement())
  sign_request_id Int
  email          String?
  name           String?
  role           String?
  signing_order  Int?          // Thứ tự ký (1, 2, 3...) cho sequential signing
  status         String?
  otp            String?
  otp_expire     DateTime?
  signed_at      DateTime?
  position_data  Json?
  signing_token  String?       @unique
  signature_data String?       // Base64 image hoặc path to signature file
  signature_type String?       // 'drawn', 'uploaded', 'typed', 'certificate'
  ip_address     String?       // IP address khi ký
  user_agent     String?       // Browser/device info
  sign_request   sign_requests @relation(fields: [sign_request_id], references: [id])
  assigned_fields sign_request_fields[]
  field_values   sign_request_field_values[]
}

model audit_logs {
  id          Int       @id @default(autoincrement())
  document_id Int
  event       String?
  user_id     Int?
  ip          String?
  ua          String?
  created_at  DateTime  @default(now())
  document    documents @relation(fields: [document_id], references: [id])
  user        users?    @relation(fields: [user_id], references: [id])
}

model license {
  id          Int      @id @default(autoincrement())
  tenant      String?
  license_key String?
  expire_date DateTime?
  limit_user  Int?
  limit_docs  Int?
  signature   String?
}

model departments {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  code        String?   @db.VarChar(50)
  name        String
  parent_id   Int?
  manager_id  Int?
  description String?
  created_at  DateTime  @default(now())
  tenant      tenants   @relation(fields: [tenant_id], references: [id])
  parent      departments? @relation("department_hierarchy", fields: [parent_id], references: [id])
  children    departments[] @relation("department_hierarchy")
  manager     users?    @relation("department_manager", fields: [manager_id], references: [id])
  users       users[]   @relation("user_department")
  documents   documents[]

  @@unique([tenant_id, code], name: "departments_tenant_id_code_key")
}

model positions {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  code        String    @db.VarChar(50)
  name        String
  description String?
  level       Int?
  is_active   Boolean   @default(true)
  created_at  DateTime  @default(now())
  tenant      tenants   @relation(fields: [tenant_id], references: [id])
  users       users[]   @relation("user_position")

  @@unique([tenant_id, code])
  @@index([tenant_id])
}

model roles {
  id          Int       @id @default(autoincrement())
  tenant_id   Int
  name        String
  description String?
  is_system   Boolean   @default(false)
  created_at  DateTime  @default(now())
  tenant      tenants   @relation(fields: [tenant_id], references: [id])
  user_roles  user_roles[]
  role_permissions role_permissions[]
  
  @@unique([tenant_id, name])
}

model permissions {
  id          Int       @id @default(autoincrement())
  resource    String
  action      String
  description String?
  role_permissions role_permissions[]
  
  @@unique([resource, action])
}

model role_permissions {
  role_id       Int
  permission_id Int
  role          roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission    permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  
  @@id([role_id, permission_id])
}

model user_roles {
  user_id     Int
  role_id     Int
  assigned_at DateTime  @default(now())
  user        users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role        roles     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  
  @@id([user_id, role_id])
}

model document_types {
  id                      Int       @id @default(autoincrement())
  tenant_id               Int
  code                    String
  name                    String
  description             String?
  require_numbering       Boolean   @default(true)
  require_digital_signing Boolean   @default(false)
  require_approval        Boolean   @default(false)
  default_workflow_id     Int?
  allow_workflow_override Boolean   @default(false)
  category                String?
  is_active               Boolean   @default(true)
  created_at              DateTime  @default(now())
  
  tenant                  tenants   @relation(fields: [tenant_id], references: [id])
  documents               documents[]
  numbering_rules         numbering_rules[]
  workflows               workflows[]
  default_workflow        workflows? @relation("default_workflow", fields: [default_workflow_id], references: [id])
  
  @@unique([tenant_id, code])
}

model numbering_rules {
  id                Int       @id @default(autoincrement())
  tenant_id         Int
  document_type_id  Int
  pattern           String
  reset_yearly      Boolean   @default(true)
  last_number       Int       @default(0)
  last_reset_year   Int?
  is_active         Boolean   @default(true)
  created_at        DateTime  @default(now())
  
  tenant            tenants   @relation(fields: [tenant_id], references: [id])
  document_type     document_types @relation(fields: [document_type_id], references: [id])
  
  @@unique([tenant_id, document_type_id])
}

model external_organizations {
  id             Int       @id @default(autoincrement())
  tenant_id      Int
  name           String
  code           String?
  category       String?
  address        String?
  phone          String?
  email          String?
  contact_person String?
  is_active      Boolean   @default(true)
  created_at     DateTime  @default(now())
  
  tenant         tenants   @relation(fields: [tenant_id], references: [id])
  
  @@unique([tenant_id, code])
}

model document_tags {
  document_id Int
  tag         String
  created_at  DateTime  @default(now())
  
  document    documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  
  @@id([document_id, tag])
}

model document_permissions {
  id          Int       @id @default(autoincrement())
  document_id Int
  subject_type String
  subject_id  Int
  can_read    Boolean   @default(true)
  can_edit    Boolean   @default(false)
  can_approve Boolean   @default(false)
  can_share   Boolean   @default(false)
  can_delete  Boolean   @default(false)
  granted_by  Int?
  granted_at  DateTime  @default(now())
  
  document    documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  
  @@unique([document_id, subject_type, subject_id])
}

model document_versions {
  id          Int       @id @default(autoincrement())
  document_id Int
  version_no  Int
  file_path   String
  file_size   Int?
  uploaded_by Int?
  uploaded_at DateTime  @default(now())
  comment     String?
  
  document    documents @relation(fields: [document_id], references: [id], onDelete: Cascade)
  
  @@unique([document_id, version_no])
}

model workflows {
  id                Int       @id @default(autoincrement())
  tenant_id         Int
  name              String
  description       String?
  document_type_id  Int?
  is_template       Boolean   @default(true)
  created_for_doc   Int?
  based_on_template Int?
  is_active         Boolean   @default(true)
  created_by        Int?
  created_at        DateTime  @default(now())
  
  tenant            tenants   @relation(fields: [tenant_id], references: [id])
  document_type     document_types? @relation(fields: [document_type_id], references: [id])
  steps             workflow_steps[]
  instances         workflow_instances[]
  approvals         document_approvals[]
  as_default        document_types[] @relation("default_workflow")
  
  @@unique([tenant_id, name])
}

model workflow_steps {
  id              Int       @id @default(autoincrement())
  workflow_id     Int
  step_order      Int
  step_name       String
  approver_type   String    // 'user', 'role', 'department', 'manager'
  approver_id     Int?
  due_in_days     Int       @default(3)
  is_required     Boolean   @default(true)
  is_parallel     Boolean   @default(false) // true = gửi cùng lúc với bước trước, false = chờ bước trước xong
  conditions      Json?
  created_at      DateTime  @default(now())
  
  workflow        workflows @relation(fields: [workflow_id], references: [id], onDelete: Cascade)
  approvals       document_approvals[]
  instances       workflow_instances[] @relation("current_step")
  
  @@unique([workflow_id, step_order])
}

model workflow_instances {
  id              Int       @id @default(autoincrement())
  document_id     Int
  workflow_id     Int
  current_step_id Int?
  status          String    @default("in_progress") // 'in_progress', 'completed', 'rejected', 'cancelled'
  started_at      DateTime  @default(now())
  completed_at    DateTime?
  
  document        documents @relation(fields: [document_id], references: [id])
  workflow        workflows @relation(fields: [workflow_id], references: [id])
  current_step    workflow_steps? @relation("current_step", fields: [current_step_id], references: [id])
  
  @@unique([document_id])
}

model document_approvals {
  id                Int       @id @default(autoincrement())
  document_id       Int
  workflow_id       Int
  workflow_step_id  Int
  approver_user_id  Int
  action            String    @default("pending") // 'pending', 'approved', 'rejected', 'request_info'
  comment           String?
  signature_data    String?   // Base64 image or signature path
  signature_type    String?   // 'drawn', 'uploaded', 'typed', 'certificate'
  acted_at          DateTime?
  due_date          DateTime?
  created_at        DateTime  @default(now())
  
  document          documents @relation(fields: [document_id], references: [id])
  workflow          workflows @relation(fields: [workflow_id], references: [id])
  workflow_step     workflow_steps @relation(fields: [workflow_step_id], references: [id])
  approver          users @relation(fields: [approver_user_id], references: [id])
}

model sign_request_fields {
  id                Int       @id @default(autoincrement())
  sign_request_id   Int
  document_id       Int
  assigned_signer_id Int?

  type              String    // 'signature' | 'text' | 'date' | 'checkbox'
  page              Int
  x                 Float
  y                 Float
  width             Float?
  height            Float?

  required          Boolean   @default(true)
  label             String?
  placeholder       String?
  read_only         Boolean   @default(false)

  created_at        DateTime  @default(now())

  sign_request      sign_requests @relation(fields: [sign_request_id], references: [id], onDelete: Cascade)
  document          documents      @relation(fields: [document_id], references: [id], onDelete: Cascade)
  assigned_signer   signers?       @relation(fields: [assigned_signer_id], references: [id], onDelete: SetNull)
  values            sign_request_field_values[]

  @@index([sign_request_id])
  @@index([document_id])
}

model sign_request_field_values {
  id           Int       @id @default(autoincrement())
  field_id     Int
  signer_id    Int
  value        Json
  filled_at    DateTime  @default(now())

  field        sign_request_fields @relation(fields: [field_id], references: [id], onDelete: Cascade)
  signer       signers            @relation(fields: [signer_id], references: [id], onDelete: Cascade)

  @@unique([field_id, signer_id], name: "field_id_signer_id")
  @@index([field_id])
  @@index([signer_id])
}

model document_cc_emails {
  id          Int       @id @default(autoincrement())
  document_id Int
  email       String
  sent_at     DateTime?
  created_at  DateTime  @default(now())

  document    documents @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
}

model document_attachments {
  id          Int       @id @default(autoincrement())
  document_id Int
  file_name   String
  file_path   String
  file_size   BigInt?
  file_type   String?
  uploaded_at DateTime  @default(now())

  document    documents @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([document_id])
}
