{
  "compilerOptions": {
    "target": "ES5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next-ux011/types/**/*.ts",
    ".next-ux-navigation/types/**/*.ts",
    ".next-ux006/types/**/*.ts",
    ".next-ux001/types/**/*.ts",
    ".next-ux016/types/**/*.ts",
    ".next-ux009/types/**/*.ts",
    ".next-ux007/types/**/*.ts",
    ".next-ux008/types/**/*.ts",
    ".next-ux005/types/**/*.ts",
    ".next-ux003/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
