# Frontend Environment Variables
# Copy this file to .env.local and update with your values

# REQUIRED: Backend API URL (no fallback - must be set)
# Development: http://localhost:4000/api/v1
# Production: https://your-domain.com/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# REQUIRED: Alternative API URL format (used by some components)
# Development: http://localhost:4000/api/v1
# Production: https://your-domain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Playwright Testing (optional - only needed for E2E tests)
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_API_BASE_URL=http://localhost:4000/api/v1
PLAYWRIGHT_EMAIL=admin@acme.local
PLAYWRIGHT_PASSWORD=admin123
