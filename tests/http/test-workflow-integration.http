### Workflow Integration Test

@baseUrl = http://localhost:4000/api/v1
@token = {{login.response.body.data.token}}

### 1. Login as admin
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@acme.local",
  "password": "Admin123!@#"
}

### 2. Upload document (Hợp đồng - require approval + signing)
# @name uploadDoc
POST {{baseUrl}}/documents
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "file_name": "hop-dong-test.pdf",
  "file_base64": "",
  "document_type_id": 3,
  "title": "Hợp đồng mua bán test"
}

### 3. Check document created with sign_request_id
GET {{baseUrl}}/documents/{{uploadDoc.response.body.data.document.id}}
Authorization: Bearer {{token}}

### 4. Get sign request editor
GET {{baseUrl}}/sign-requests/{{uploadDoc.response.body.data.document.sign_request_id}}/editor
Authorization: Bearer {{token}}

### 5. Add sign fields
POST {{baseUrl}}/sign-requests/{{uploadDoc.response.body.data.document.sign_request_id}}/fields
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "fields": [
    {
      "type": "signature",
      "page": 1,
      "x": 100,
      "y": 200,
      "width": 200,
      "height": 80,
      "required": true,
      "label": "Chữ ký bên A",
      "assigned_signer_id": 1
    },
    {
      "type": "text",
      "page": 1,
      "x": 100,
      "y": 300,
      "width": 300,
      "height": 40,
      "required": true,
      "label": "Họ tên",
      "assigned_signer_id": 1
    }
  ]
}

### 6. Submit for approval
POST {{baseUrl}}/documents/{{uploadDoc.response.body.data.document.id}}/submit-for-approval
Authorization: Bearer {{token}}
Content-Type: application/json

{}

### 7. Check document status (should be pending_approval)
GET {{baseUrl}}/documents/{{uploadDoc.response.body.data.document.id}}
Authorization: Bearer {{token}}

### 8. Get pending approvals
GET {{baseUrl}}/approvals/my-pending
Authorization: Bearer {{token}}

### 9. Approve (as admin)
# @name approval
POST {{baseUrl}}/approvals/1/approve
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "comment": "Đồng ý"
}

### 10. Check document status (should be pending_signature after approval)
GET {{baseUrl}}/documents/{{uploadDoc.response.body.data.document.id}}
Authorization: Bearer {{token}}

### 11. Check sign request status (should be pending)
GET {{baseUrl}}/sign-requests/{{uploadDoc.response.body.data.document.sign_request_id}}
Authorization: Bearer {{token}}

### 12. Get signers (should have signing_token)
GET {{baseUrl}}/sign-requests/{{uploadDoc.response.body.data.document.sign_request_id}}
Authorization: Bearer {{token}}
