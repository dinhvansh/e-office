# Docker MinIO/S3 E2E only. Public deterministic test credentials; never deploy.
POSTGRES_USER=eoffice_e2e
POSTGRES_PASSWORD=eoffice_e2e_postgres_password_not_for_production
POSTGRES_DB=eoffice_e2e_s3
DATABASE_URL=postgresql://eoffice_e2e:eoffice_e2e_postgres_password_not_for_production@db:5432/eoffice_e2e_s3

JWT_SECRET=e2e-only-jwt-secret-with-at-least-thirty-two-characters
REFRESH_TOKEN_SECRET=e2e-only-refresh-secret-with-at-least-thirty-two-chars
DEMO_ADMIN_PASSWORD=e2e-only-demo-password-not-for-production
E2E_ADMIN_PASSWORD=e2e-only-demo-password-not-for-production
E2E_ADMIN_EMAIL=admin@acme.local
E2E_INTERNAL_SIGNER_EMAIL=admin@acme.local

NODE_ENV=test
BACKEND_PORT=4010
CORS_ORIGIN=http://localhost:3010
APP_BASE_URL=http://localhost:3010
REDIS_URL=redis://redis:6379
FILE_STORAGE_DRIVER=s3
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=eoffice-e2e
S3_ACCESS_KEY_ID=eofficee2eaccess
S3_SECRET_ACCESS_KEY=eoffice-e2e-minio-secret-not-production
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=eofficee2eaccess
MINIO_ROOT_PASSWORD=eoffice-e2e-minio-secret-not-production
SMTP_ENABLED=false
AUTO_INIT_DB=true
DISABLE_LICENSE_CHECK=true
OUTBOX_POLL_INTERVAL_MS=250
